// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum StoryModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  sessions     AdminSession[]

  @@map("admin_users")
}

model AdminSession {
  id          String     @id @default(cuid())
  tokenHash   String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  adminUserId String

  adminUser   AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model Alumni {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  title       String
  company     String?
  location    String?
  linkedinUrl String?
  imageUrl    String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  stories     Story[]
  
  @@map("alumni")
}

model Story {
  id               String               @id @default(cuid())
  title            String
  slug             String               @unique
  content          String
  videoUrl         String?
  thumbnailUrl     String?
  publishedAt      String               @default("")
  isPublished      Boolean              @default(false)
  isFeatured       Boolean              @default(false)
  moderationStatus StoryModerationStatus @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  alumniId    String
  alumni      Alumni   @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  
  categories  StoryCategory[]
  tags        StoryTag[]
  
  @@map("stories")
}

model VideoTestimonial {
  id           String   @id @default(cuid())
  title        String
  summary      String
  name         String
  role         String
  company      String
  duration     String
  videoUrl     String
  thumbnailUrl  String
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("video_testimonials")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  stories     StoryCategory[]
  
  @@map("categories")
}

model StoryCategory {
  storyId     String
  categoryId  String
  
  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@id([storyId, categoryId])
  @@map("story_categories")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  
  stories   StoryTag[]
  
  @@map("tags")
}

model StoryTag {
  storyId String
  tagId   String
  
  story   Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([storyId, tagId])
  @@map("story_tags")
}
