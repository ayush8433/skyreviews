generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]

  @@map("admin_users")
}

model AdminSession {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model Alumni {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  title        String
  company      String?
  location     String?
  linkedinUrl  String?
  imageUrl     String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projectTitle String?
  projectUrl   String?
  stories      Story[]

  @@map("alumni")
}

model Story {
  id                 String                @id @default(cuid())
  title              String
  slug               String                @unique
  content            String
  videoUrl           String?
  thumbnailUrl       String?
  publishedAt        String                @default("")
  isPublished        Boolean               @default(false)
  isFeatured         Boolean               @default(false)
  moderationStatus   StoryModerationStatus @default(PENDING)
  metaJson           String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  alumniId           String
  placementManagerId String?
  placementManager   PlacementManager?     @relation(fields: [placementManagerId], references: [id])
  alumni             Alumni                @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  categories         StoryCategory[]
  tags               StoryTag[]

  @@map("stories")
}

model VideoTestimonial {
  id                 String            @id @default(cuid())
  title              String
  summary            String
  name               String
  role               String
  company            String
  duration           String
  videoUrl           String
  thumbnailUrl       String
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  placementManagerId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  placementManager   PlacementManager? @relation(fields: [placementManagerId], references: [id])

  @@map("video_testimonials")
}

model Category {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  stories     StoryCategory[]

  @@map("categories")
}

model StoryCategory {
  storyId    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, categoryId])
  @@map("story_categories")
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  stories   StoryTag[]

  @@map("tags")
}

model StoryTag {
  storyId String
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, tagId])
  @@map("story_tags")
}

model PlacementManager {
  id               String                   @id @default(cuid())
  name             String
  role             String
  linkedinUrl      String?
  imageUrl         String?
  bio              String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  slug             String?                  @unique
  reviews          PlacementManagerReview[]
  videos           PlacementManagerVideo[]
  assignedPodcasts Podcast[]
  assignedStories  Story[]
  assignedVideos   VideoTestimonial[]

  @@map("placement_managers")
}

model PlacementManagerReview {
  id                 String           @id @default(cuid())
  reviewerName       String
  reviewerRole       String?
  content            String
  rating             Int              @default(5)
  placementManagerId String
  createdAt          DateTime         @default(now())
  placementManager   PlacementManager @relation(fields: [placementManagerId], references: [id], onDelete: Cascade)

  @@map("placement_manager_reviews")
}

model PlacementManagerVideo {
  id                 String           @id @default(cuid())
  title              String
  videoUrl           String
  thumbnailUrl       String?
  placementManagerId String
  createdAt          DateTime         @default(now())
  placementManager   PlacementManager @relation(fields: [placementManagerId], references: [id], onDelete: Cascade)

  @@map("placement_manager_videos")
}

model Podcast {
  id                 String            @id @default(cuid())
  title              String
  description        String
  youtubeUrl         String
  videoUrl           String?
  thumbnailUrl       String?
  isActive           Boolean           @default(true)
  placementManagerId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  placementManager   PlacementManager? @relation(fields: [placementManagerId], references: [id])

  @@map("podcasts")
}

model OptOutRequest {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  reason    String?
  createdAt DateTime @default(now())

  @@map("opt_out_requests")
}

model StudentCertification {
  id                  String   @id @default(cuid())
  studentName         String
  program             String
  certCode            String
  certName            String
  issueDate           String
  certificateImageUrl String?
  linkedinUrl         String?
  testimonial         String?
  isPublished         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("student_certifications")
}

enum StoryModerationStatus {
  PENDING
  APPROVED
  REJECTED
}
