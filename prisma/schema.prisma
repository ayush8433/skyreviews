// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum StoryModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  sessions     AdminSession[]

  @@map("admin_users")
}

model AdminSession {
  id          String     @id @default(cuid())
  tokenHash   String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  adminUserId String

  adminUser   AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model Alumni {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  title        String
  company      String?
  location     String?
  linkedinUrl  String?
  imageUrl     String?
  bio          String?
  projectTitle String?
  projectUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  stories     Story[]
  
  @@map("alumni")
}

model Story {
  id               String               @id @default(cuid())
  title            String
  slug             String               @unique
  content          String
  videoUrl         String?
  thumbnailUrl     String?
  publishedAt      String               @default("")
  isPublished      Boolean              @default(false)
  isFeatured       Boolean              @default(false)
  moderationStatus StoryModerationStatus @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  alumniId    String
  alumni      Alumni   @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  
  categories  StoryCategory[]
  tags        StoryTag[]
  
  @@map("stories")
}

model VideoTestimonial {
  id           String   @id @default(cuid())
  title        String
  summary      String
  name         String
  role         String
  company      String
  duration     String
  videoUrl     String
  thumbnailUrl  String
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("video_testimonials")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  stories     StoryCategory[]
  
  @@map("categories")
}

model StoryCategory {
  storyId     String
  categoryId  String
  
  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@id([storyId, categoryId])
  @@map("story_categories")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  
  stories   StoryTag[]
  
  @@map("tags")
}

model StoryTag {
  storyId String
  tagId   String
  
  story   Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([storyId, tagId])
  @@map("story_tags")
}

model PlacementManager {
  id          String                   @id @default(cuid())
  name        String
  role        String
  linkedinUrl String?
  imageUrl    String?
  bio         String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  reviews     PlacementManagerReview[]
  videos      PlacementManagerVideo[]

  @@map("placement_managers")
}

model PlacementManagerReview {
  id                 String           @id @default(cuid())
  reviewerName       String
  reviewerRole       String?
  content            String
  rating             Int              @default(5)
  placementManagerId String
  placementManager   PlacementManager @relation(fields: [placementManagerId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@map("placement_manager_reviews")
}

model PlacementManagerVideo {
  id                 String           @id @default(cuid())
  title              String
  videoUrl           String
  thumbnailUrl       String?
  placementManagerId String
  placementManager   PlacementManager @relation(fields: [placementManagerId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@map("placement_manager_videos")
}

model Podcast {
  id           String   @id @default(cuid())
  title        String
  description  String
  youtubeUrl   String
  videoUrl     String?
  thumbnailUrl String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("podcasts")
}

model OptOutRequest {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  reason    String?
  createdAt DateTime @default(now())

  @@map("opt_out_requests")
}

model StudentCertification {
  id                 String   @id @default(cuid())
  studentName        String
  program            String
  certCode           String   // e.g. "DP-900", "AZ-900"
  certName           String   // e.g. "Microsoft Azure Data Fundamentals"
  issueDate          String   // e.g. "2025-03-15" stored as string for SQLite
  certificateImageUrl String?
  linkedinUrl        String?
  testimonial        String?  // short quote about the certification experience
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("student_certifications")
}
